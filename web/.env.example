# ─── Database (NeonDB) ────────────────────────────────────
# Get from: Neon Console → Project → Connection Details
# DATABASE_URL: pooled connection (…-pooler.…neon.tech) — used by the app (serverless driver)
# DIRECT_URL:   direct connection (no -pooler) — used by drizzle-kit migrations
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# ─── Pharos Atlantic Testnet ──────────────────────────────
PHAROS_NETWORK=atlantic-testnet
PHAROS_CHAIN_ID=688689
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_EXPLORER=https://atlantic.pharosscan.xyz
X402_NETWORK=eip155:688689

# USDC on Pharos Atlantic — VERIFIED on-chain (Circle USDC, symbol=USDC, 6 decimals).
# This is the token the faucet dispenses on Atlantic.
USDC_ADDRESS=0xcfC8330f4BCAB529c625D12781b1C19466A9Fc8B
USDC_DECIMALS=6

# Optional PHRS faucet endpoint (best-effort funding at Genesis)
PHAROS_FAUCET_URL=

# NEXT_PUBLIC_ variants for client-side code (launch page / wallet connect)
NEXT_PUBLIC_PHAROS_CHAIN_ID=688689
NEXT_PUBLIC_PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
NEXT_PUBLIC_PHAROS_EXPLORER=https://atlantic.pharosscan.xyz
# Client-side payment + Genesis (launch page / agent detail)
NEXT_PUBLIC_USDC_ADDRESS=0xcfC8330f4BCAB529c625D12781b1C19466A9Fc8B
NEXT_PUBLIC_OPERATOR_ADDRESS=0xYOUR_OPERATOR_ADDRESS

# ─── Operator / Treasury (server-side signing) ───────────
# EVM private key (0x...) that holds the treasury and pays gas for Mitos/USDC
# settlement (distribute, buyback, token sale). NEVER commit.
PHAROS_OPERATOR_PRIVATE_KEY=0xYOUR_OPERATOR_KEY
PHAROS_OPERATOR_ADDRESS=0xYOUR_OPERATOR_ADDRESS

# ─── x402 Facilitator (self-hosted — packages/facilitator) ─
FACILITATOR_URL=http://localhost:4020

# ─── Talos Contracts on Pharos Atlantic ──────────────────
# Run: cd contracts && pnpm deploy:atlantic (prints addresses)
NEXT_PUBLIC_TALOS_REGISTRY_CONTRACT=0x...
NEXT_PUBLIC_TALOS_NAME_SERVICE_CONTRACT=0x...

# ─── Per-agent signing keys (provisioned at Genesis) ─────
# For each Talos, store its agent wallet private key (returned once as
# agentWalletKeyOnce) so the server can sign x402 purchases on its behalf:
#   TALOS_AGENT_SECRET_<talosId>=0x...

# ─── AI Services ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...

# Shared x402 seller resource server (packages/seller)
SELLER_PUBLIC_URL=http://localhost:4021
