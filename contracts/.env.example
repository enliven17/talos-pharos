# ─── Pharos Atlantic Testnet ──────────────────────────────
# Chain ID : 688689
# RPC      : https://atlantic.dplabs-internal.com
# Explorer : https://atlantic.pharosscan.xyz/
# Gas      : PHRS (request from Pharos faucet / Telegram)

PHAROS_RPC_URL=https://atlantic.dplabs-internal.com

# ─── Deployer ─────────────────────────────────────────────
# EVM private key (0x...). NEVER commit. Fund with PHRS for gas.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# ─── Protocol Wallet ──────────────────────────────────────
# Receives the 3% launchpad fee policy reference. EVM address (0x...).
# Defaults to deployer if not set.
TALOS_PROTOCOL_WALLET=0xYOUR_PROTOCOL_WALLET

# ─── Explorer verification (optional) ─────────────────────
PHAROSSCAN_API_KEY=

# ─── Post-Deployment (auto-printed by scripts/deploy.ts) ──
# Copy these into web/.env.local as NEXT_PUBLIC_* too.
# TALOS_REGISTRY_CONTRACT=0x...
# TALOS_NAME_SERVICE_CONTRACT=0x...
